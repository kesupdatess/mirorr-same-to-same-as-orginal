<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Support KES Updates - Donation</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            max-width: 500px;
            width: 100%;
            padding: 40px;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            color: #333;
            font-size: 28px;
            margin-bottom: 10px;
        }

        .header p {
            color: #666;
            font-size: 14px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #333;
            font-weight: 600;
            font-size: 14px;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 14px;
            transition: border-color 0.3s;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #667eea;
        }

        .btn {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .btn:hover {
            transform: translateY(-2px);
        }

        .btn-generate {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            margin-bottom: 20px;
        }

        .qr-section {
            display: none;
            text-align: center;
            padding: 20px;
            background: #f8f9fa;
            border-radius: 15px;
            margin-bottom: 20px;
        }

        .qr-section img {
            max-width: 250px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .qr-section h3 {
            margin-bottom: 15px;
            color: #333;
        }

        .upi-id {
            background: #e3f2fd;
            padding: 10px;
            border-radius: 8px;
            margin: 15px 0;
            font-family: monospace;
            font-size: 16px;
            color: #1976d2;
        }

        .upload-section {
            display: none;
            margin-top: 20px;
        }

        .file-input-wrapper {
            position: relative;
            overflow: hidden;
            display: inline-block;
            width: 100%;
        }

        .file-input-wrapper input[type=file] {
            position: absolute;
            left: -9999px;
        }

        .file-label {
            display: block;
            padding: 15px;
            background: #f0f0f0;
            border: 2px dashed #ccc;
            border-radius: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }

        .file-label:hover {
            background: #e8e8e8;
            border-color: #667eea;
        }

        .btn-submit {
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
            color: white;
            display: none;
        }

        .success-message {
            display: none;
            text-align: center;
            padding: 30px;
        }

        .success-message .icon {
            font-size: 60px;
            margin-bottom: 15px;
        }

        .success-message h2 {
            color: #11998e;
            margin-bottom: 10px;
        }

        .loading {
            display: none;
            text-align: center;
            padding: 20px;
        }

        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #667eea;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 15px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .amount-display {
            font-size: 24px;
            font-weight: bold;
            color: #667eea;
            margin: 10px 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>🎓 Support KES Updates</h1>
            <p>Your contribution helps us keep students informed</p>
        </div>

        <!-- Form Section -->
        <div id="formSection">
            <div class="form-group">
                <label for="name">Full Name *</label>
                <input type="text" id="name" placeholder="Enter your name" required>
            </div>

            <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" placeholder="Enter your email" required>
            </div>

            <div class="form-group">
                <label for="amount">Donation Amount (₹) *</label>
                <input type="number" id="amount" placeholder="Enter amount (min ₹10)" min="10" required>
            </div>

            <div class="form-group">
                <label for="message">Message (Optional)</label>
                <textarea id="message" rows="3" placeholder="Any message for the team..."></textarea>
            </div>

            <button class="btn btn-generate" onclick="generateQR()">
                Generate QR Code & Pay
            </button>
        </div>

        <!-- QR Section -->
        <div id="qrSection" class="qr-section">
            <h3>Scan & Pay</h3>
            <div class="amount-display">₹<span id="displayAmount">0</span></div>
            <img id="qrImage" src="" alt="UPI QR Code">
            <div class="upi-id" id="upiDisplay">test@okaxis</div>
            <p style="margin-top: 10px; color: #666; font-size: 12px;">
                Open any UPI app and scan this code
            </p>

            <div class="upload-section" id="uploadSection">
                <p style="margin-bottom: 15px; font-weight: 600;">Upload Payment Screenshot *</p>
                <div class="file-input-wrapper">
                    <input type="file" id="screenshot" accept="image/*" onchange="handleFileSelect()">
                    <label for="screenshot" class="file-label" id="fileLabel">
                        📷 Click to upload screenshot
                    </label>
                </div>
            </div>

            <button class="btn btn-submit" id="submitBtn" onclick="submitDonation()">
                Submit Donation
            </button>
        </div>

        <!-- Loading -->
        <div id="loading" class="loading">
            <div class="spinner"></div>
            <p>Processing...</p>
        </div>

        <!-- Success -->
        <div id="success" class="success-message">
            <div class="icon">✅</div>
            <h2>Thank You!</h2>
            <p>Your donation has been recorded.</p>
            <p style="margin-top: 10px; color: #666; font-size: 14px;">
                Status: <strong>Pending Verification</strong>
            </p>
        </div>
    </div>

    <script>
        // Supabase Config
        const SUPABASE_URL = 'https://uegdizdnminwhkxcdcle.supabase.co';
        const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVlZ2RpemRubWlud2hreGNkY2xlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIwODk2MjgsImV4cCI6MjA5NzY2NTYyOH0.2wiAHbaoNoDva_tRseDAywVMu_6AioCGlVLgoVb0d6s';

        const supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        let donationData = {};
        let selectedFile = null;

        // Generate QR Code
        function generateQR() {
            const name = document.getElementById('name').value.trim();
            const email = document.getElementById('email').value.trim();
            const amount = document.getElementById('amount').value;
            const message = document.getElementById('message').value.trim();

            // Validation
            if (!name || !email || !amount) {
                alert('Please fill all required fields!');
                return;
            }

            if (amount < 10) {
                alert('Minimum donation amount is ₹10');
                return;
            }

            // Save data
            donationData = { name, email, amount: parseInt(amount), message };

            // Show QR section
            document.getElementById('formSection').style.display = 'none';
            document.getElementById('qrSection').style.display = 'block';
            document.getElementById('displayAmount').textContent = amount;

            // Generate QR using QRServer API (free, no key needed)
            const upiUrl = `upi://pay?pa=test@okaxis&pn=KES%20Updates&am=${amount}`;
            const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=${encodeURIComponent(upiUrl)}`;
            document.getElementById('qrImage').src = qrUrl;

            // Show upload section after 2 seconds
            setTimeout(() => {
                document.getElementById('uploadSection').style.display = 'block';
            }, 2000);
        }

        // Handle file selection
        function handleFileSelect() {
            const file = document.getElementById('screenshot').files[0];
            if (file) {
                selectedFile = file;
                document.getElementById('fileLabel').textContent = `✅ ${file.name}`;
                document.getElementById('submitBtn').style.display = 'block';
            }
        }

        // Submit donation
        async function submitDonation() {
            if (!selectedFile) {
                alert('Please upload payment screenshot!');
                return;
            }

            document.getElementById('qrSection').style.display = 'none';
            document.getElementById('loading').style.display = 'block';

            try {
                // Upload screenshot to Supabase Storage
                const fileExt = selectedFile.name.split('.').pop();
                const fileName = `donation_${Date.now()}.${fileExt}`;

                const { data: uploadData, error: uploadError } = await supabase.storage
                    .from('donation-screenshots')
                    .upload(fileName, selectedFile);

                if (uploadError) throw uploadError;

                // Get public URL
                const { data: urlData } = supabase.storage
                    .from('donation-screenshots')
                    .getPublicUrl(fileName);

                const screenshotUrl = urlData.publicUrl;

                // Save donation data
                const { data, error } = await supabase
                    .from('donations')
                    .insert([
                        {
                            name: donationData.name,
                            email: donationData.email,
                            amount: donationData.amount,
                            message: donationData.message || null,
                            screenshot_url: screenshotUrl,
                            status: 'pending'
                        }
                    ]);

                if (error) throw error;

                // Show success
                document.getElementById('loading').style.display = 'none';
                document.getElementById('success').style.display = 'block';

            } catch (err) {
                console.error('Error:', err);
                alert('Something went wrong! Please try again.');
                document.getElementById('loading').style.display = 'none';
                document.getElementById('qrSection').style.display = 'block';
            }
        }
    </script>
</body>
</html>
